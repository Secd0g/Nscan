# Copy to deploy/.env.production and replace every CHANGE_ME value.
COMPOSE_PROJECT_NAME=nscan-production
DOMAIN=nscan.example.com
WEB_PORT=80
HTTPS_PORT=443
GRPC_PORT=9000

REGISTRY=local
IMAGE_TAG=1.0.0
SERVER_IMAGE=nscan-server:release
SCANNER_IMAGE=nscan-scanner:release
BUILD_LOCAL=true
PUSH_IMAGES=false

# 当前环境推荐使用公共 ECR 基础镜像，企业环境可替换为内部镜像仓库。
GO_IMAGE=public.ecr.aws/docker/library/golang:1.26-bookworm
NODE_IMAGE=public.ecr.aws/docker/library/node:20-slim
DEBIAN_IMAGE=public.ecr.aws/docker/library/debian:bookworm-slim
INSTALL_AI_TOOLS=false
INSTALL_OPTIONAL_TOOLS=false

AUTH_TOKEN=CHANGE_ME_RANDOM_NODE_TOKEN
JWT_SECRET=CHANGE_ME_RANDOM_JWT_SECRET
ADMIN_USER=admin
ADMIN_PASS=CHANGE_ME_STRONG_ADMIN_PASSWORD
MONGO_ROOT_USER=nscan
MONGO_ROOT_PASS=CHANGE_ME_MONGO_PASSWORD
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

MAX_TASKS=5
QUEUE_MODE=redis
QUEUE_WORKERS=0
CAPABILITIES=search,subdomain,shuffledns,port,http,crawler,nuclei,brute,dir,sensitive,ai-pentest
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=
